{
  "name": "nerdscave/whmcs-sevdesk",
  "description": "Resumable WHMCS to sevdesk voucher export module",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.3",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*"
  },
  "require-dev": {
    "guzzlehttp/guzzle": "^7.9",
    "illuminate/database": "^10.48",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5",
    "squizlabs/php_codesniffer": "^3.13"
  },
  "autoload": {
    "psr-4": {
      "WHMCS\\Module\\Addon\\SevDesk\\": "modules/addons/sevdesk/lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WHMCS\\Module\\Addon\\SevDesk\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": false,
    "sort-packages": true
  },
  "scripts": {
    "lint": "find modules/addons/sevdesk tests -type f -name '*.php' -print0 | xargs -0 -n1 php -l",
    "cs": "phpcs",
    "cs:fix": "phpcbf",
    "stan": "phpstan analyse --memory-limit=1G",
    "test": "phpunit",
    "test:integration": "phpunit --configuration phpunit.integration.xml.dist"
  }
}
